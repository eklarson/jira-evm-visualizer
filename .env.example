# Jira configuration (when using jira-integration-wrapper or direct API)
JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=your_api_token_here

# Default IMS XML path (optional)
DEFAULT_IMS_XML_PATH=/data/weekly_ims_export.xml

# Project key to pull hierarchy from
JIRA_PROJECT_KEY=PROJ

# Logging
LOG_LEVEL=INFO